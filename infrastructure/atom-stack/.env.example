ATOM_STACK_PROJECT_NAME=atom-host
ATOM_STACK_NETWORK=atom-host-net

ATOM_HOST_IMAGE=nginx:1.27.0-alpine
ATOM_HOST_PORT=62080
ATOM_HOST_INTERNAL_PORT=8080
ATOM_HOST_HEALTH_PATH=/healthz

ATOM_DB_IMAGE=mariadb:11.4.2
ATOM_DB_NAME=atom
ATOM_DB_USER=atom
ATOM_DB_PASSWORD=REPLACE_WITH_SECURE_DB_PASSWORD
ATOM_DB_ROOT_PASSWORD=REPLACE_WITH_SECURE_ROOT_PASSWORD
ATOM_DB_PORT=63306

ATOM_CACHE_IMAGE=redis:7.4.2-alpine
ATOM_CACHE_PORT=63790

ATOM_STACK_WAIT_TIMEOUT=240
WORKBENCH_PLUGIN_API_BASE_URL=http://localhost:62080/plugins/homicide-tracker/api
