ATOM_STACK_PROJECT_NAME=atom-host
ATOM_STACK_NETWORK=atom-host-net
ATOM_STACK_SERVICE=atom

ATOM_HOST_IMAGE=nginx:1.27.0-alpine
ATOM_HOST_PORT=62080
ATOM_HOST_INTERNAL_PORT=8080
ATOM_HOST_HEALTH_PATH=/healthz

# Optional override when building from source (defaults to stable/2.10.x):
# ATOM_APP_BUILD_CONTEXT=https://github.com/artefactual/atom.git#stable/2.10.x
# ATOM_APP_DOCKERFILE=Dockerfile

ATOM_DB_IMAGE=mariadb:11.4.2
ATOM_DB_NAME=atom
ATOM_DB_USER=atom
ATOM_DB_PASSWORD=REPLACE_WITH_SECURE_DB_PASSWORD
ATOM_DB_ROOT_PASSWORD=REPLACE_WITH_SECURE_ROOT_PASSWORD
ATOM_DB_PORT=63306

ATOM_CACHE_IMAGE=redis:7.4.2-alpine
ATOM_CACHE_PORT=63790

ATOM_STACK_WAIT_TIMEOUT=240
WORKBENCH_PLUGIN_API_BASE_URL=http://localhost:62080/plugins/homicide-tracker/api

# Plugin bootstrap hooks
# Default plugin-only enablement is idempotent and skips if sfArticlePlugin is already enabled.
# ATOM_BOOTSTRAP_PLUGIN_HOOK=if php symfony plugins | grep -Eq '(^|[ \t])sfArticlePlugin([ \t]|$)'; then echo 'sfArticlePlugin already enabled'; else php symfony plugins:enable sfArticlePlugin; fi
#
# Default reset hook is plugin-only and skips if sfArticlePlugin is already disabled.
# ATOM_BOOTSTRAP_RESET_HOOK=if php symfony plugins | grep -Eq '(^|[ \t])sfArticlePlugin([ \t]|$)'; then php symfony plugins:disable sfArticlePlugin; else echo 'sfArticlePlugin already disabled'; fi
#
# Optional core bootstrap hooks (disabled by default for plugin-only scope).
# ATOM_BOOTSTRAP_ADMIN_HOOK=php -d memory_limit=${ATOM_INSTALL_MEMORY_LIMIT:-2G} symfony tools:install --database-host="${ATOM_DB_HOST:-atom-db}" --database-port="${ATOM_DB_PORT:-3306}" --database-name="${ATOM_DB_NAME:-atom}" --database-user="${ATOM_DB_USER:-atom}" --database-password="${ATOM_DB_PASSWORD:-REPLACE_WITH_SECURE_DB_PASSWORD}" --search-host="${ATOM_SEARCH_HOST:-elasticsearch}" --search-port="${ATOM_SEARCH_PORT:-9200}" --search-index="${ATOM_SEARCH_INDEX:-atom}" --site-title="${ATOM_SITE_NAME:-AtoM}" --site-description="${ATOM_SITE_DESCRIPTION:-Local AtoM dev stack}" --site-base-url="${ATOM_SITE_BASE_URL:-http://127.0.0.1:62080}" --admin-email="${ATOM_ADMIN_EMAIL:-admin@example.invalid}" --admin-username="${ATOM_ADMIN_USERNAME:-admin}" --admin-password="${ATOM_ADMIN_PASSWORD:-Admin123!}" --no-confirmation
# ATOM_BOOTSTRAP_BASELINE_HOOK=php symfony search:populate
#
# Optional post-enable plugin hook for hosted runtime assets/cache.
# ATOM_BOOTSTRAP_PLUGIN_HOOK=php symfony plugin:publish-assets sfHomicideMediaTrackerPlugin && php symfony cc
